# Flask
SECRET_KEY=change-me-to-a-random-string
PORT=5060

# Database. Leave unset for local SQLite dev (data/portal.db).
# On Render, set to the managed Postgres connection string.
DATABASE_URL=

# Storage backend: "local" (dev, serves storage/videos/ from disk) or "r2" (Cloudflare R2, prod)
STORAGE_BACKEND=local

# Cloudflare R2 (only needed when STORAGE_BACKEND=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Anthropic (for auto-generated quizzes)
ANTHROPIC_API_KEY=

# First admin account, created automatically on first run if it doesn't exist
ADMIN_NAME=Matt Kirkham
ADMIN_USERNAME=matt
ADMIN_PASSWORD=change-me
